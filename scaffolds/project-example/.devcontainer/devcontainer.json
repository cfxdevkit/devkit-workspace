{
  // CFX DevKit project scaffold — devcontainer configuration.
  //
  // This generated repository can be opened directly in GitHub Codespaces or
  // locally with the VS Code Dev Containers extension.

  "name": "CFX DevKit Project",

  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },

  "remoteUser": "node",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],

  "init": true,
  "overrideCommand": false,

  "postCreateCommand": "pnpm install",

  "forwardPorts": [3030, 7748, 8545, 8546, 8888, 12537, 12535],
  "portsAttributes": {
    "7748": {
      "label": "DevKit Backend API",
      "onAutoForward": "silent"
    },
    "3030": {
      "label": "DEX UI",
      "onAutoForward": "silent"
    },
    "8545": {
      "label": "Conflux eSpace RPC",
      "onAutoForward": "silent"
    },
    "8546": {
      "label": "Conflux eSpace WS",
      "onAutoForward": "silent"
    },
    "8888": {
      "label": "Conflux Dev Dashboard",
      "onAutoForward": "silent"
    },
    "12537": {
      "label": "Conflux Core Space RPC",
      "onAutoForward": "silent"
    },
    "12535": {
      "label": "Conflux Core Space WS",
      "onAutoForward": "silent"
    }
  },

  "customizations": {
    "vscode": {
      "settings": {
        "workbench.colorTheme": "Default Dark Modern",
        "workbench.preferredDarkColorTheme": "Default Dark Modern",
        "window.autoDetectColorScheme": false,
        "workbench.startupEditor": "none",
        "extensions.autoUpdate": false,
        "extensions.autoCheckUpdates": false,
        "telemetry.telemetryLevel": "off",
        "update.mode": "none",
        "remote.autoForwardPorts": false,
        "remote.autoForwardPortsSource": "output",
        "devkit.devPort": 3001
      }
    }
  }
}