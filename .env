# Docker socket path — docker compose reads this automatically.
# Change to match your container runtime:
#   Docker:         DOCKER_SOCKET=/var/run/docker.sock
#   Podman rootless: DOCKER_SOCKET=/run/user/1000/podman/podman.sock
DOCKER_SOCKET=/run/user/1000/podman/podman.sock

# Optional: GitHub PAT for Copilot auth inside the container
# GITHUB_TOKEN=ghp_...

# Optional: override the workspace folder that code-server opens
# WORKSPACE=/home/node/project
