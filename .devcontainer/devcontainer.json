{
  // CFX DevKit — devcontainer configuration.
  //
  // Works in two environments:
  //   • GitHub Codespaces — native VS Code browser interface, no local install needed
  //   • Local VS Code     — Dev Containers extension (requires Docker Desktop or Podman)
  //
  // Builds from .devcontainer/Dockerfile which extends the pre-built workspace image
  // and replaces the code-server entrypoint with a lightweight wrapper that
  // starts the backend before handing control to the command injected by
  // Codespaces / Dev Containers.
  //
  // On every start:
  //   - The devkit backend is started by the container entrypoint on port 7748.
  //   - The devkit VS Code extension is already present in the remote server's
  //     extensions directory before VS Code attaches.
  //
  // Docker socket access (DooD) is enabled so the devkit extension can manage the
  // inner Conflux devkit stack (Hardhat node, block-streaming, etc.).

  "name": "CFX DevKit Workspace",

  "build": {
    "dockerfile": "Dockerfile"
  },

  // Run as the non-root node user that owns all devkit files in the image.
  "remoteUser": "node",

  // Open the baked-in example project as the workspace (same as the standalone image).
  // Local Dev Containers: the repo folder is still accessible via the filesystem.
  // Codespaces: the cloned repo is at /workspaces/<repo>; devkit workspace at /opt/devkit/project-example.
  "workspaceFolder": "/opt/devkit/project-example",

  // Mount the Docker socket so the devkit extension can spin up/down the inner stack.
  // Codespaces exposes /var/run/docker.sock automatically; local Docker does too.
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],

  // Use a real entrypoint so the backend starts as part of container startup,
  // not as a best-effort lifecycle hook racing with VS Code attachment.
  "init": true,

  // Forward all ports that devkit services listen on so they are reachable
  // from the browser / local machine via VS Code port forwarding.
  "forwardPorts": [3030, 7748, 8545, 8546, 8888, 12537, 12535],
  "portsAttributes": {
    "7748": {
      "label": "DevKit Backend API",
      "onAutoForward": "silent"
    },
    "3030": {
      "label": "DEX UI",
      "onAutoForward": "silent"
    },
    "8545": {
      "label": "Conflux eSpace RPC",
      "onAutoForward": "silent"
    },
    "8546": {
      "label": "Conflux eSpace WS",
      "onAutoForward": "silent"
    },
    "8888": {
      "label": "Conflux Dev Dashboard",
      "onAutoForward": "silent"
    },
    "12537": {
      "label": "Conflux Core Space RPC",
      "onAutoForward": "silent"
    },
    "12535": {
      "label": "Conflux Core Space WS",
      "onAutoForward": "silent"
    }
  },

  "customizations": {
    "vscode": {
      // Marketplace extensions installed automatically.
      // The custom devkit extension is pre-seeded in the image.
      "extensions": [
        "sst-dev.opencode"
      ],
      // Mirror the settings from config/settings.json (baked into the image for code-server;
      // applied here for the native VS Code remote server).
      "settings": {
        "workbench.colorTheme": "Default Dark Modern",
        "workbench.preferredDarkColorTheme": "Default Dark Modern",
        "window.autoDetectColorScheme": false,
        "workbench.startupEditor": "none",
        "extensions.autoUpdate": false,
        "extensions.autoCheckUpdates": false,
        "telemetry.telemetryLevel": "off",
        "update.mode": "none",
        "remote.autoForwardPorts": false,
        "remote.autoForwardPortsSource": "output",
        "devkit.devPort": 3001
      }
    }
  }
}
