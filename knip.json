{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "package.json",
    "scripts/**/*.{js,mjs,cjs}"
  ],
  "project": [
    "**/*.{ts,tsx,js,mjs,cjs,cts,mts}",
    "!**/node_modules/**",
    "!**/dist/**",
    "!**/out/**",
    "!**/.generated/**",
    "!packages/contracts/hh-artifacts/**",
    "!packages/contracts/hh-cache/**",
    "!packages/contracts/typechain-types/**"
  ],
  "ignoreDependencies": [
    "@xcfx/node",
    "@openzeppelin/contracts",
    "@uniswap/lib",
    "@uniswap/v2-core",
    "@uniswap/v2-periphery",
    "solc"
  ],
  "workspaces": {
    "packages/ui-shared": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ]
    },
    "dex-ui": {
      "entry": [
        "src/main.tsx",
        "src/App.tsx"
      ],
      "project": [
        "src/**/*.{ts,tsx}"
      ]
    },
    "scaffolds/project-example/dapp": {
      "entry": [
        "src/main.tsx",
        "vite.config.ts",
        "server.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "*.{ts,tsx,mts,cts}"
      ]
    },
    "packages/contracts": {
      "entry": [
        "hardhat.config.cts",
        "scripts/**/*.{js,mjs,cjs,ts}",
        "generated/**/*.ts"
      ],
      "project": [
        "hardhat.config.cts",
        "scripts/**/*.{js,mjs,cjs,ts}",
        "generated/**/*.ts"
      ]
    }
  }
}
