{
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*.cjs",
      "**/*.cts",
      "**/*.js",
      "**/*.json",
      "**/*.jsonc",
      "**/*.jsx",
      "**/*.mjs",
      "**/*.mts",
      "**/*.ts",
      "**/*.tsx",
      "!**/node_modules",
      "!**/dist",
      "!**/dist-server",
      "!packages/contracts/artifacts",
      "!packages/contracts/generated",
      "!packages/contracts/typechain-types",
      "!packages/contracts/hh-artifacts",
      "!packages/contracts/hh-cache",
      "!opencode.json",
      "!.opencode",
      "!.generated"
    ]
  },
  "linter": {
    "enabled": true
  }
}
