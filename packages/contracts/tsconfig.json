{
	"ts-node": {
		"compilerOptions": {
			"module": "commonjs",
			"moduleResolution": "node"
		}
	},
	"compilerOptions": {
		"target": "ES2020",
		"module": "ES2020",
		"moduleResolution": "bundler",
		"lib": ["ES2020"],
		"strict": true,
		"esModuleInterop": true,
		"declaration": true,
		"outDir": "./dist",
		"rootDir": "./generated",
		"skipLibCheck": true
	},
	"include": ["generated/**/*.ts"],
	"exclude": ["node_modules"]
}
