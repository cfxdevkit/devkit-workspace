{
  "name": "conflux-workspace",
  "version": "0.1.4",
  "description": "Manage and launch the CFX DevKit workspace container with per-workspace persistence profiles",
  "homepage": "https://github.com/cfxdevkit/devkit-workspace#readme",
  "bugs": {
    "url": "https://github.com/cfxdevkit/devkit-workspace/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cfxdevkit/devkit-workspace.git"
  },
  "keywords": [
    "conflux",
    "cfx",
    "docker",
    "devcontainer",
    "workspace",
    "cli"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "conflux-workspace": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ./scripts/sync-template.mjs && tsc -p ./ && chmod +x dist/cli.js",
    "typecheck": "tsc -p ./ --noEmit",
    "watch": "tsc -watch -p ./"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
