{
	"name": "devkit-workspace-ext",
	"displayName": "DevKit Workspace",
	"description": "Conflux blockchain development environment — node lifecycle, contract deployment, Docker Compose, and devcontainer tooling",
	"version": "0.0.0",
	"publisher": "local",
	"private": true,
	"files": [
		"out/**/*",
		"media/**/*",
		"scripts/**/*",
		"README.md"
	],
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Other"
	],
	"extensionKind": [
		"ui",
		"workspace"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./out/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "cfxdevkit-sidebar",
					"title": "Conflux DevKit",
					"icon": "media/cfxdevkit.svg"
				}
			]
		},
		"commands": [
			{
				"command": "devkit.stackUp",
				"title": "Project: Stack Up"
			},
			{
				"command": "devkit.stackRebuild",
				"title": "Project: Stack Rebuild (with image rebuild)"
			},
			{
				"command": "devkit.stackDown",
				"title": "Project: Stack Down"
			},
			{
				"command": "devkit.stackRestart",
				"title": "Project: Stack Restart"
			},
			{
				"command": "devkit.stackLogs",
				"title": "Project: Stack Logs (follow)"
			},
			{
				"command": "devkit.stackPs",
				"title": "Project: Stack Status"
			},
			{
				"command": "devkit.openCompose",
				"title": "Project: Open Compose File"
			},
			{
				"command": "devkit.syncSettings",
				"title": "DevKit: Sync Workspace Settings"
			},
			{
				"command": "devkit.openDevcontainer",
				"title": "DevKit: Open devcontainer.json"
			},
			{
				"command": "devkit.checkDocker",
				"title": "DevKit: Check Docker"
			},
			{
				"command": "devkit.start",
				"title": "Project: Start Services",
				"icon": "$(play)"
			},
			{
				"command": "devkit.stop",
				"title": "Project: Stop Services",
				"icon": "$(debug-stop)"
			},
			{
				"command": "devkit.status",
				"title": "Project: Services Status",
				"icon": "$(pulse)"
			},
			{
				"command": "devkit.deployProjectContracts",
				"title": "Project: Deploy Contracts",
				"icon": "$(cloud-upload)"
			},
			{
				"command": "devkit.startDev",
				"title": "Project: Start Dev Server",
				"icon": "$(play)"
			},
			{
				"command": "devkit.stopDev",
				"title": "Project: Stop Dev Server",
				"icon": "$(debug-stop)"
			},
			{
				"command": "devkit.refreshStatus",
				"title": "Project: Refresh Status Bar"
			},
			{
				"command": "devkit.projectDoctor",
				"title": "Project: Doctor (Health Check)",
				"icon": "$(heart)"
			},
			{
				"command": "cfxdevkit.selectNetwork",
				"title": "Conflux: Select Network",
				"icon": "$(globe)"
			},
			{
				"command": "cfxdevkit.serverStart",
				"title": "Conflux: Start DevKit Server"
			},
			{
				"command": "cfxdevkit.serverStop",
				"title": "Conflux: Stop Node"
			},
			{
				"command": "cfxdevkit.initializeSetup",
				"title": "Conflux: Initialize Wallet (Setup Wizard)"
			},
			{
				"command": "cfxdevkit.unlockKeystore",
				"title": "Conflux: Unlock Keystore"
			},
			{
				"command": "cfxdevkit.nodeStart",
				"title": "Conflux: Start Node",
				"icon": "$(play)"
			},
			{
				"command": "cfxdevkit.nodeStop",
				"title": "Conflux: Stop Node",
				"icon": "$(debug-stop)"
			},
			{
				"command": "cfxdevkit.nodeRestart",
				"title": "Conflux: Restart Node"
			},
			{
				"command": "cfxdevkit.nodeWipeRestart",
				"title": "Conflux: Wipe Data & Restart Node"
			},
			{
				"command": "cfxdevkit.nodeWipe",
				"title": "Conflux: Wipe Blockchain Data"
			},
			{
				"command": "cfxdevkit.openUI",
				"title": "Conflux: Open DevKit UI"
			},
			{
				"command": "cfxdevkit.viewAccounts",
				"title": "Conflux: View Accounts"
			},
			{
				"command": "cfxdevkit.deployContract",
				"title": "Conflux: Deploy Contract",
				"icon": "$(cloud-upload)"
			},
			{
				"command": "cfxdevkit.deployDex",
				"title": "Conflux: Deploy DEX (Uniswap V2)",
				"icon": "$(pulse)"
			},
			{
				"command": "cfxdevkit.listContracts",
				"title": "Conflux: List Deployed Contracts"
			},
			{
				"command": "cfxdevkit.importContract",
				"title": "Conflux: Import Contract",
				"icon": "$(cloud-download)"
			},
			{
				"command": "cfxdevkit.mineBlocks",
				"title": "Conflux: Mine Blocks"
			},
			{
				"command": "cfxdevkit.shutdown",
				"title": "Conflux: Shut Down Stack",
				"icon": "$(debug-stop)"
			},
			{
				"command": "cfxdevkit.copyAddress",
				"title": "Conflux: Copy Address",
				"icon": "$(copy)"
			},
			{
				"command": "cfxdevkit.refreshAccounts",
				"title": "Conflux: Refresh Accounts",
				"icon": "$(refresh)"
			},
			{
				"command": "cfxdevkit.refreshContracts",
				"title": "Conflux: Refresh Contracts",
				"icon": "$(refresh)"
			},
			{
				"command": "cfxdevkit.abiCallRead",
				"title": "Conflux: Call Read Function",
				"category": "Conflux"
			},
			{
				"command": "cfxdevkit.abiCallWrite",
				"title": "Conflux: Call Write Function",
				"category": "Conflux"
			},
			{
				"command": "cfxdevkit.copyContractAddress",
				"title": "Conflux: Copy Contract Address",
				"category": "Conflux"
			},
			{
				"command": "cfxdevkit.dexUiStart",
				"title": "DEX UI: Start",
				"icon": "$(play)"
			},
			{
				"command": "cfxdevkit.dexUiStop",
				"title": "DEX UI: Stop",
				"icon": "$(debug-stop)"
			},
			{
				"command": "cfxdevkit.dexUiRestart",
				"title": "DEX UI: Restart",
				"icon": "$(refresh)"
			},
			{
				"command": "cfxdevkit.dexUiRefresh",
				"title": "DEX UI: Refresh Status Bar"
			},
			{
				"command": "cfxdevkit.dexUiSetup",
				"title": "DEX UI: Setup Dependencies",
				"icon": "$(gear)"
			},
			{
				"command": "cfxdevkit.dexUiShowLogs",
				"title": "DEX UI: Show Output Logs",
				"icon": "$(output)"
			}
		],
		"views": {
			"cfxdevkit-sidebar": [
				{
					"id": "cfxdevkit.networkView",
					"name": "Network",
					"icon": "$(globe)"
				},
				{
					"id": "cfxdevkit.nodeView",
					"name": "Local Node",
					"icon": "$(server)"
				},
				{
					"id": "cfxdevkit.accountsView",
					"name": "Accounts",
					"icon": "$(person)",
					"when": "cfxdevkit.serverOnline"
				},
				{
					"id": "cfxdevkit.contractsView",
					"name": "Deployed Contracts",
					"icon": "$(file-code)",
					"when": "cfxdevkit.serverOnline"
				},
				{
					"id": "cfxdevkit.dexView",
					"name": "DEX Pools",
					"icon": "$(pulse)",
					"when": "cfxdevkit.nodeRunning"
				}
			]
		},
		"viewsWelcome": [
			{
				"view": "cfxdevkit.networkView",
				"contents": "Select a Conflux network to connect to.\n[Select Network](command:cfxdevkit.selectNetwork)"
			},
			{
				"view": "cfxdevkit.nodeView",
				"contents": "Manage the local Conflux dev node.\n[Start Server](command:cfxdevkit.serverStart)"
			},
			{
				"view": "cfxdevkit.accountsView",
				"contents": "No accounts loaded yet.\n\nInitialize your wallet to see genesis accounts.\n[Initialize Wallet](command:cfxdevkit.initializeSetup)\n[Start Node](command:cfxdevkit.nodeStart)"
			},
			{
				"view": "cfxdevkit.contractsView",
				"contents": "No contracts deployed yet.\n\nDeploy or import a contract to see it listed here.\n[Deploy Contract](command:cfxdevkit.deployContract)\n[Import Contract](command:cfxdevkit.importContract)"
			},
			{
				"view": "cfxdevkit.dexView",
				"contents": "No DEX pools deployed yet.\n\nUse the MCP tools to deploy and seed a Uniswap V2 DEX:\n1. dex_deploy — Deploy V2 stack\n2. dex_seed_from_gecko — Seed pools with real prices"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "cfxdevkit.selectNetwork",
					"when": "view == cfxdevkit.networkView",
					"group": "navigation@1"
				},
				{
					"command": "cfxdevkit.refreshAccounts",
					"when": "view == cfxdevkit.accountsView",
					"group": "navigation@1"
				},
				{
					"command": "cfxdevkit.deployContract",
					"when": "view == cfxdevkit.contractsView",
					"group": "navigation@1"
				},
				{
					"command": "cfxdevkit.importContract",
					"when": "view == cfxdevkit.contractsView",
					"group": "navigation@2"
				},
				{
					"command": "cfxdevkit.refreshContracts",
					"when": "view == cfxdevkit.contractsView",
					"group": "navigation@3"
				}
			],
			"view/item/context": [
				{
					"command": "cfxdevkit.copyAddress",
					"when": "viewItem == cfxAddressItem",
					"group": "inline"
				}
			]
		},
		"configuration": {
			"title": "DevKit Workspace",
			"properties": {
				"devkit.deployCommand": {
					"type": "string",
					"default": "",
					"description": "Shell command to deploy project contracts (run from workspace root). If empty, looks for scripts/deploy-contract.mjs, then falls back to the contract picker."
				},
				"devkit.devPort": {
					"type": "number",
					"default": 3001,
					"description": "Port to probe when checking whether the dev server is running (default: 3001 for this workspace's Vite app)"
				},
				"devkit.devCommand": {
					"type": "string",
					"default": "pnpm dev",
					"description": "Shell command to start the dev server (run from workspace root)"
				},
				"devkit.installCommand": {
					"type": "string",
					"default": "pnpm install",
					"description": "Shell command to install project dependencies (run from workspace root)"
				},
				"devkit.composeFile": {
					"type": "string",
					"default": "docker-compose.yml",
					"description": "Path to the Docker Compose file, relative to workspace root"
				},
				"devkit.composeProjectName": {
					"type": "string",
					"default": "",
					"description": "Docker Compose project name (-p flag). Leave empty to use the directory name."
				},
				"devkit.packageManager": {
					"type": "string",
					"enum": [
						"pnpm",
						"npm",
						"yarn"
					],
					"default": "pnpm",
					"description": "Package manager used by the Project menu script contract (pnpm run / npm run / yarn)."
				},
				"devkit.scriptDoctor": {
					"type": "string",
					"default": "doctor",
					"description": "package.json script name to execute for Project Doctor."
				},
				"devkit.scriptInstall": {
					"type": "string",
					"default": "deps:install",
					"description": "package.json script name for dependency installation from the Project menu."
				},
				"devkit.scriptContractsDeploy": {
					"type": "string",
					"default": "deploy",
					"description": "package.json script name for contract deployment from the Project menu."
				},
				"devkit.scriptClean": {
					"type": "string",
					"default": "clean",
					"description": "package.json script name to clean the workspace."
				},
				"devkit.scriptDevStart": {
					"type": "string",
					"default": "dev",
					"description": "package.json script name to start the dev environment."
				},
				"devkit.scriptDevStop": {
					"type": "string",
					"default": "",
					"description": "Optional package.json script name to stop the dev environment."
				},
				"devkit.scriptProdStart": {
					"type": "string",
					"default": "stack:up",
					"description": "package.json script name to start production preview."
				},
				"devkit.scriptProdStop": {
					"type": "string",
					"default": "stack:down",
					"description": "package.json script name to stop production preview."
				},
				"devkit.scriptProdRebuild": {
					"type": "string",
					"default": "stack:rebuild",
					"description": "package.json script name to rebuild production preview artifacts/services."
				},
				"devkit.scriptProdStatus": {
					"type": "string",
					"default": "stack:status",
					"description": "package.json script name to inspect production preview status."
				},
				"devkit.scriptProdLogs": {
					"type": "string",
					"default": "stack:logs",
					"description": "Optional package.json script name to stream production preview logs."
				},
				"devkit.contractsArtifactPath": {
					"type": "string",
					"default": "dapp/src/generated/contracts-addresses.ts",
					"description": "Relative path to generated TypeScript chainId/address artifact used by frontend lookup."
				},
				"devkit.prodPort": {
					"type": "number",
					"default": 3030,
					"description": "Port to open when browsing the production Docker Compose stack."
				},
				"cfxdevkit.port": {
					"type": "number",
					"default": 7748,
					"description": "Port for the conflux-devkit server (default: 7748)"
				},
				"cfxdevkit.autoStart": {
					"type": "boolean",
					"default": false,
					"description": "Automatically start the conflux-devkit server when the workspace opens"
				},
				"cfxdevkit.enabled": {
					"type": "boolean",
					"default": true,
					"description": "Show the Conflux dev node status bar item."
				},
				"cfxdevkit.espaceRpc": {
					"type": "string",
					"default": "http://127.0.0.1:8545",
					"description": "eSpace (EVM) JSON-RPC endpoint"
				},
				"cfxdevkit.coreRpc": {
					"type": "string",
					"default": "http://127.0.0.1:12537",
					"description": "Core Space JSON-RPC endpoint"
				},
				"cfxdevkit.accountsCount": {
					"type": "number",
					"default": 5,
					"minimum": 1,
					"description": "Default number of genesis accounts for new local wallets."
				},
				"cfxdevkit.dexServerScript": {
					"type": "string",
					"default": "/opt/devkit/apps/dex-ui/server.mjs",
					"description": "Absolute path to the DEX UI server.mjs entry-point inside the devcontainer image."
				},
				"cfxdevkit.dexUiPort": {
					"type": "number",
					"default": 8888,
					"description": "Port the DEX UI server listens on (default: 8888)."
				},
				"cfxdevkit.dexAutoStartWhenDeployed": {
					"type": "boolean",
					"default": true,
					"description": "If true, the DEX status bar auto-starts the DEX UI when DEX contracts are detected as deployed."
				}
			}
		}
	},
	"scripts": {
		"build": "tsc -p ./",
		"compile": "tsc -p ./",
		"typecheck": "tsc -p ./ --noEmit",
		"watch": "tsc -watch -p ./",
		"check": "node ./scripts/check.mjs",
		"package": "npx @vscode/vsce package --no-dependencies --allow-missing-repository --skip-license --out ../../dist/devkit.vsix",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"devDependencies": {
		"@devkit/shared": "workspace:*",
		"@types/node": "^20.0.0",
		"@types/vscode": "^1.85.0",
		"@vscode/vsce": "^3.6.2",
		"typescript": "^5.3.0",
		"vitest": "^2.0.0"
	},
	"license": "Apache-2.0"
}
