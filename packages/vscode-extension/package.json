{
  "name": "new-devkit-workspace-ext",
  "displayName": "New DevKit Workspace",
  "description": "Shared VS Code extension baked into new-devkit editor images",
  "version": "0.0.0",
  "publisher": "local",
  "private": true,
  "files": [
    "src/**/*",
    "scripts/**/*",
    "README.md"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:newDevkit.showStatus"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "newDevkit.showStatus",
        "title": "New DevKit: Show Backend Status"
      }
    ]
  },
  "scripts": {
    "check": "node ./scripts/check.mjs",
    "package": "npx @vscode/vsce package --no-dependencies --allow-missing-repository --skip-license --out ../../dist/devkit.vsix"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2"
  }
}
