{
  "name": "@cfxdevkit/mcp",
  "version": "0.1.0",
  "description": "MCP server for CFX DevKit — Conflux blockchain development tools for AI agents",
  "type": "module",
  "bin": {
    "devkit-mcp": "./dist/index.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": "./dist/server.js",
    "./cli": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p ./ && chmod +x dist/index.js",
    "typecheck": "tsc -p ./ --noEmit",
    "watch": "tsc -watch -p ./",
    "dev": "tsc -watch -p ./",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cfxdevkit/dex-contracts": "workspace:*",
    "@cfxdevkit/compiler": "^1.2.4",
    "@cfxdevkit/core": "^1.2.4",
    "@cfxdevkit/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "license": "Apache-2.0"
}
