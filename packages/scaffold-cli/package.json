{
	"name": "@cfxdevkit/scaffold-cli",
	"private": false,
	"version": "0.2.0",
	"type": "module",
	"description": "Scaffold-only CLI for devkit templates and targets",
	"files": [
		"src",
		"assets"
	],
	"bin": {
		"scaffold-cli": "src/cli.js"
	},
	"main": "./src/cli.js",
	"scripts": {
		"prepare-package": "node ./scripts/prepare-package.mjs",
		"prepack": "node ./scripts/prepare-package.mjs",
		"pack:dry-run": "pnpm pack --dry-run",
		"publish:dry-run": "npm publish --dry-run --access public",
		"publish:npm": "npm publish --access public"
	},
	"license": "Apache-2.0",
	"author": "cfxdevkit <noreply@cfxdevkit.org>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/cfxdevkit/conflux-devkit-workspace.git"
	},
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@inquirer/prompts": "^7.0.0"
	}
}
