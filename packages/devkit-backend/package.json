{
	"name": "@devkit/devkit-backend",
	"version": "0.0.0",
	"private": true,
	"description": "Shared backend runtime baked into devkit infrastructure images",
	"bin": {
		"devkit-backend": "./dist/cli.js"
	},
	"main": "./dist/cli.js",
	"files": [
		"dist/**/*",
		"README.md"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
