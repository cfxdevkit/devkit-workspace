{
  "name": "@cfxdevkit/devkit-backend",
  "version": "0.1.6",
  "private": true,
  "description": "Vendored conflux-devkit backend for local refinement and upstream backporting",
  "bin": {
    "devkit-backend": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
